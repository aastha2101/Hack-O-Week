<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cozy Corner Stationery</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:'Poppins',sans-serif;
}

body{
background:#fdf6f9;
}

header{
background:#ff9aa2;
color:white;
text-align:center;
padding:25px;
}

header h1{
font-weight:600;
}

.container{
width:90%;
margin:auto;
padding:40px 0;
}

.products{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:25px;
}

.card{
background:white;
border-radius:15px;
overflow:hidden;
box-shadow:0 6px 15px rgba(0,0,0,0.08);
transition:0.3s;
}

.card:hover{
transform:translateY(-6px);
}

.card img{
width:100%;
height:180px;
object-fit:cover;
}

.product-info{
padding:15px;
text-align:center;
}

.product-info h3{
margin-bottom:6px;
font-size:18px;
}

.price{
color:#ff6f91;
font-weight:600;
margin-bottom:10px;
}

button{
padding:8px 18px;
border:none;
background:#ff6f91;
color:white;
border-radius:20px;
cursor:pointer;
transition:0.3s;
}

button:hover{
background:#ff4d73;
}

footer{
text-align:center;
padding:15px;
background:#ff9aa2;
color:white;
margin-top:40px;
}

</style>
</head>

<body>

<header>
<h1>📚 Cozy Corner Stationery</h1>
<p>Cute & Affordable Supplies</p>
</header>

<div class="container">

<div class="products">

<div class="card">
<img src="https://assets-production.mochithings.com/products/15554/photos/square_thumbnail_80094-simple-pastel-notebook-e70608.jpg">
<div class="product-info">
<h3>Pastel Notebook</h3>
<p class="price">₹99</p>
<button>Buy</button>
</div>
</div>

<div class="card">
<img src="https://encrypted-tbn0.gstatic.com/shopping?q=tbn:ANd9GcRxVbDVZOnfjNGDAkew34mSKAA20oT2l0aPLz6zc8P58HtZd1G_42J0TbysZtpwWPNb8ZJbgLC8_jxBE-jHVyrbUJ40lHdkwZHMNAE4ito&usqp=CAc">
<div class="product-info">
<h3>Gel Pen Set</h3>
<p class="price">₹79</p>
<button>Buy</button>
</div>
</div>

<div class="card">
<img src="https://m.media-amazon.com/images/I/61cJKTbts1L.jpg">
<div class="product-info">
<h3>Sticky Notes Pack</h3>
<p class="price">₹59</p>
<button>Buy</button>
</div>
</div>

<div class="card">
<img src="https://m.media-amazon.com/images/I/41d0Ks+ABvL.jpg">
<div class="product-info">
<h3>Highlighter Set</h3>
<p class="price">₹129</p>
<button>Buy</button>
</div>
</div>

<div class="card">
<img src="https://m.media-amazon.com/images/I/31He0xYcPfL._SY300_SX300_QL70_FMwebp_.jpg">
<div class="product-info">
<h3>Planner Journal</h3>
<p class="price">₹149</p>
<button>Buy</button>
</div>
</div>

<div class="card">
<img src="https://roomtery.com/cdn/shop/products/kawaii-white-desktop-storage-box-organizer-roomtery12.jpg?v=1675357350">
<div class="product-info">
<h3>Desk Organizer</h3>
<p class="price">₹199</p>
<button>Buy</button>
</div>
</div>

<div class="card">
<img src="https://encrypted-tbn2.gstatic.com/shopping?q=tbn:ANd9GcQilKqkwZTKR69y5teIBISSrabiMUk68F_QM_Cbf0mmGMPDvvv1FORphcrqCq8KCVTSeOYFkP3hka0W_VY5AHAYVEGFsIgRuColknCW6CyFqoN3WheWzFaC">
<div class="product-info">
<h3>Color Pencil Set</h3>
<p class="price">₹89</p>
<button>Buy</button>
</div>
</div>

<div class="card">
<img src="https://encrypted-tbn3.gstatic.com/shopping?q=tbn:ANd9GcQRFj3Ol0MRooDy4_T7QD2VbdF74VTPiPE-Mxejv-YDPVY1D047XopSiOr_r9BeQdNJmafhZAbYnVBYaYafShi6FrGcaV3EGrzvUt5GKxQb6lJvlRbFWUGL">
<div class="product-info">
<h3>Mini Stapler</h3>
<p class="price">₹69</p>
<button>Buy</button>
</div>
</div>

</div>

</div>

<footer>
<p>© 2026 Cozy Corner Stationery</p>
</footer>

</body>
</html>
